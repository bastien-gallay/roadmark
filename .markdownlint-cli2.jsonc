{
  // Project docs: enforce 80-col prose, but don't fight tables / code blocks
  // / anchor HTML.
  "config": {
    "MD013": { "line_length": 80, "tables": false, "code_blocks": false },
    // Keep a Changelog repeats "### Added"/"### Changed" per version.
    "MD024": { "siblings_only": true },
    "MD033": false
  },
  // Lint every doc by default, so a bare `markdownlint-cli2` mirrors CI
  // (whose action passes the same glob explicitly).
  "globs": ["**/*.md"],
  // CLAUDE.md is only an `@AGENTS.md` import pointer, not prose. Feature
  // files (fixtures + examples + our own .roadmap/) are frontmatter data
  // whose body starts with a summary paragraph by design, not an H1.
  // ROADMAP.md is a generated artifact.
  "ignores": [
    "target/**",
    "node_modules/**",
    "CLAUDE.md",
    "ROADMAP.md",
    ".roadmap/features/**",
    "examples/.roadmap/features/**",
    "tests/fixtures/**"
  ]
}
